# Frontend (Vite) — nunca commitar .env com secrets reais
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key
VITE_CHAMPIONSHIP_ID=ch1
# Mesmo valor que CHECKIN_HMAC_SECRET na Edge checkin-validate (apenas demo local)
VITE_CHECKIN_DEV_SECRET=dev-checkin-secret

# Opcional: Gemini no cliente (insights); fluxos sensíveis usam Edge Function
GEMINI_API_KEY=

# Edge Functions (definir no painel Supabase / supabase secrets)
# GEMINI_API_KEY= — para gemini-suggest
# RESEND_API_KEY= — para send-notification
# PAYMENT_WEBHOOK_SECRET= — para validar webhook Pix
